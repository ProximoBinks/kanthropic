{
  "name": "kanthropic-vscode",
  "displayName": "kanthropic",
  "description": "A kana flashcard panel that opens beside Claude Code while it's thinking, and closes when it's done.",
  "version": "0.1.0",
  "publisher": "kanthropic",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Education", "Other"],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kanthropic.openPanel",
        "title": "kanthropic: Open kana panel"
      },
      {
        "command": "kanthropic.closePanel",
        "title": "kanthropic: Close kana panel"
      },
      {
        "command": "kanthropic.toggleScript",
        "title": "kanthropic: Toggle hiragana / katakana"
      }
    ],
    "configuration": {
      "title": "kanthropic",
      "properties": {
        "kanthropic.script": {
          "type": "string",
          "enum": ["hiragana", "katakana"],
          "default": "hiragana",
          "description": "Which script the panel drills."
        },
        "kanthropic.closeOnStop": {
          "type": "boolean",
          "default": true,
          "description": "Automatically close the panel when Claude finishes (the Stop hook). Turn off to keep it open between prompts."
        }
      }
    }
  }
}
