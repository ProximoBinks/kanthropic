{
  "name": "kanthropic",
  "version": "0.1.2",
  "description": "Learn hiragana & katakana in the dead time while Claude Code is thinking — a kana flashcard pane that pops up beside Claude while it works.",
  "type": "module",
  "bin": {
    "kanthropic": "src/cli/index.mjs"
  },
  "files": [
    "src",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit --allowJs --checkJs -p jsconfig.json || true",
    "prepublishOnly": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chafa-wasm": "^0.3.3",
    "opentype.js": "^2.0.0",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "vitest": "^2.0.5"
  },
  "keywords": [
    "kana",
    "hiragana",
    "katakana",
    "japanese",
    "flashcards",
    "fsrs",
    "spaced-repetition",
    "claude",
    "claude-code",
    "cli",
    "tmux",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProximoBinks/kanthropic.git"
  },
  "homepage": "https://github.com/ProximoBinks/kanthropic#readme",
  "bugs": {
    "url": "https://github.com/ProximoBinks/kanthropic/issues"
  },
  "license": "MIT",
  "author": "Elliot Koh"
}
